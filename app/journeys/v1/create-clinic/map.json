{
  "$schema": "../../../map/map.schema.json",
  "title": "Create a clinic",
  "summary": "Create a single clinic or a recurring clinic series.",
  "section": "Manage clinics",
  "status": "ready for dev",
  "steps": [
    {
      "id": "type-of-clinic",
      "title": "Type of clinic",
      "summary": "Choose a single date or a weekly series.",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Choose type", "path": "/v1/site/1/clinics/type-of-clinc", "data": {} }] }
      ]
    },
    {
      "id": "details",
      "title": "Details / dates",
      "summary": "Enter the date(s) for the clinic.",
      "defaultVariant": "series",
      "variants": [
        { "id": "series", "label": "Series", "screenshots": [{ "label": "Series dates", "path": "/v1/site/1/clinics/details", "data": { "newSession": { "type": "Clinic series" } } }] },
        { "id": "single", "label": "Single", "screenshots": [{ "label": "Single date", "path": "/v1/site/1/clinics/details", "data": { "newSession": { "type": "Single clinic" } } }] }
      ]
    },
    {
      "id": "days",
      "title": "Days of the week",
      "summary": "Pick which weekdays the series runs (series only).",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Days", "path": "/v1/site/1/clinics/days", "data": { "newSession": { "type": "Clinic series" } } }] }
      ]
    },
    {
      "id": "clinic-times",
      "title": "Times and capacity",
      "summary": "Set the hours, appointment length and capacity.",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Times", "path": "/v1/site/1/clinics/clinic-times", "data": { "newSession": { "type": "Clinic series" } } }] }
      ]
    },
    {
      "id": "services",
      "title": "Services",
      "summary": "Choose which vaccinations are offered.",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Services", "path": "/v1/site/1/clinics/services", "data": { "newSession": { "type": "Clinic series" } } }] }
      ]
    },
    {
      "id": "clinic-closures",
      "title": "Closures",
      "summary": "Add any dates the series should skip (series only).",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Closures", "path": "/v1/site/1/clinics/clinic-closures", "data": { "newSession": { "type": "Clinic series" } } }] }
      ]
    },
    {
      "id": "check-answers",
      "title": "Check answers",
      "summary": "Review before creating.",
      "defaultVariant": "default",
      "variants": [
        { "id": "default", "label": "Default", "screenshots": [{ "label": "Review", "path": "/v1/site/1/clinics/check-answers", "data": { "newSession": { "type": "Clinic series" } } }] }
      ]
    }
  ]
}
