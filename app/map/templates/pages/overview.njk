{% extends "layouts/base.njk" %}

{% block content %}
  <div class="nhsuk-width-container map-width-container">
    <h1 class="nhsuk-heading-l nhsuk-u-margin-top-6">User journeys overview</h1>

    {% for section in sections %}
      <section aria-labelledby="section-{{ section.id }}" class="nhsuk-u-margin-bottom-6">
        <h2 id="section-{{ section.id }}" class="nhsuk-heading-m nhsuk-u-margin-bottom-3">{{ section.title }}</h2>

        {% if section.journeys.length %}
          <ul class="nhsuk-grid-row nhsuk-card-group">
            {% for journey in section.journeys %}
              <li class="nhsuk-grid-column-one-half nhsuk-card-group__item">
                <article class="nhsuk-card nhsuk-card--clickable">
                  <div class="nhsuk-card__content">
                    <h3 class="nhsuk-card__heading nhsuk-heading-m">
                      <a class="nhsuk-card__link" href="{{ journey.path }}">{{ journey.title }}</a>
                    </h3>
                    <p class="nhsuk-card__description">{{ journey.summary or 'No description yet.' }}</p>
                  </div>
                </article>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="nhsuk-body">No journeys in this section yet.</p>
        {% endif %}
      </section>
    {% endfor %}
  </div>
{% endblock %}
