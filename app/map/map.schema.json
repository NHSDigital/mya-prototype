{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Journey map manifest (map.json)",
  "description": "Documents the steps, variants and screenshot-hydration data for one journey. Lives at app/journeys/<version>/<journey>/map.json; the journey id and version are inferred from the folder path.",
  "type": "object",
  "required": ["title", "steps"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "title": { "type": "string", "description": "Human-readable journey name." },
    "summary": { "type": "string", "description": "One-line description shown on the overview card." },
    "section": { "type": "string", "description": "Overview grouping heading (e.g. 'Manage availability')." },
    "status": { "type": "string", "description": "e.g. 'ready for dev', 'in progress'." },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "variants"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "description": "kebab-case step id." },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string" },
          "defaultVariant": { "type": "string", "description": "id of the variant shown by default." },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "label", "screenshots"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
                "label": { "type": "string" },
                "description": { "type": "string" },
                "alt": { "type": "string", "description": "Alt text for the screenshot." },
                "caption": { "type": "string" },
                "screenshots": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["path"],
                    "additionalProperties": false,
                    "properties": {
                      "label": { "type": "string" },
                      "path": {
                        "type": "string",
                        "pattern": "^/",
                        "description": "Concrete, version-prefixed route to capture (no :params), e.g. /v1/site/1/cancel-availability/dates."
                      },
                      "data": {
                        "type": "object",
                        "description": "State deep-merged into the session before render (closures, dates, bookings, today, features...)."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
