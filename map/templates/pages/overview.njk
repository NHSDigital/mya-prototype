{% extends "layouts/base.njk" %}
{% from "components/macros.njk" import textList %}

{% block content %}
  <section class="map-page-head map-page-head--simple">
    <div>
      <span class="map-detail-eyebrow">Prototype map</span>
      <h1 class="map-page-title">User journeys overview</h1>
      <p class="map-page-summary">
        This area is generated from versioned journey YAML in <code>/map/journeys</code>.
      </p>
    </div>
  </section>

  {% for section in sections %}
    <section class="map-overview-section" aria-labelledby="section-{{ section.id }}">
      <div class="map-overview-section__head">
        <span class="map-card-eyebrow">Section</span>
        <h2 id="section-{{ section.id }}" class="map-overview-section__title">{{ section.title }}</h2>
      </div>

      {% if section.journeys.length %}
        <div class="map-overview-grid">
          {% for journey in section.journeys %}
            <article class="map-overview-card">
              <span class="map-card-eyebrow">Journey map</span>
              <h3><a href="{{ journey.path }}">{{ journey.title }}</a></h3>
              {% if journey.summary %}
                <p>{{ journey.summary }}</p>
              {% endif %}
              <dl class="map-meta-list">
                <div>
                  <dt>Steps</dt>
                  <dd>{{ journey.latestStepCount }}</dd>
                </div>
                <div>
                  <dt>Versions</dt>
                  <dd>{{ journey.versionCount }}</dd>
                </div>
                <div>
                  <dt>Latest version</dt>
                  <dd>{{ journey.latestVersionLabel }}</dd>
                </div>
              </dl>
              {% if journey.researchSummaryPreview.length %}
                <div class="nhsuk-u-margin-top-4">
                  <span class="map-card-eyebrow">Research summary</span>
                  {{ textList(journey.researchSummaryPreview) }}
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% else %}
        <div class="map-panel map-overview-empty">
          <p class="map-empty-state">No journeys in this section yet.</p>
        </div>
      {% endif %}
    </section>
  {% endfor %}
{% endblock %}
