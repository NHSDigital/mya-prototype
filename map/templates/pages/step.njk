{% extends "layouts/base.njk" %}
{% from "components/macros.njk" import stepDetailList, stepVariantScreenshot, stepVariantResearch, stepImplementationPanel %}
{% from "nhsuk/components/tabs/macro.njk" import tabs %}
{% from "nhsuk/components/pagination/macro.njk" import pagination %}

{% macro stepVersionControl(step, journey) %}
  <div class="nhsuk-form-group">
    <label class="nhsuk-label" for="step-version">Version</label>
    <div class="map-step-control" data-map-control="step-version">
      <select
        class="nhsuk-select map-select"
        id="step-version"
        data-map-version-select
        aria-label="Choose a step version">
        {% for version in step.versionOptions %}
          <option value="{{ version.path }}" {% if version.id == journey.version.id %}selected{% endif %}>
            {{ version.label }}
          </option>
        {% endfor %}
      </select>
      {% if step.status or journey.version.tag %}
        <strong class="nhsuk-tag map-step-status">{{ step.status or journey.version.tag }}</strong>
      {% endif %}
    </div>
  </div>
{% endmacro %}

{% macro stepVariantControl(step) %}
  <div class="nhsuk-form-group">
    <label class="nhsuk-label" for="step-variant">Variant</label>
    <div class="map-step-control" data-map-control="step-variant">
      <select
        class="nhsuk-select map-select"
        id="step-variant"
        data-map-variant-select
        data-map-step-slug="{{ step.slug }}"
        data-map-default-variant-id="{{ step.defaultVariantId }}"
        aria-label="Choose a step variant">
        {% for variant in step.variants %}
          <option value="{{ variant.id }}" {% if variant.isDefaultVariant %}selected{% endif %}>{{ variant.label }}</option>
        {% endfor %}
      </select>
      <script type="application/json" data-map-variant-data>{{ step.variantIndexJson | safe }}</script>
    </div>
  </div>
{% endmacro %}

{% block content %}
  <section class="map-page-head map-page-head--simple">
    <h1 class="nhsuk-heading-l nhsuk-u-margin-bottom-2">Step {{ step.position }}: {{ step.title }}</h1>
  </section>

  <section class="nhsuk-grid-row map-step-grid">
    <aside class="nhsuk-grid-column-one-third map-step-controls">
      {{ stepVersionControl(step, journey) }}
      {{ stepVariantControl(step) }}
    </aside>

    <section class="nhsuk-grid-column-two-thirds map-step-main">
      {% set screenshotTab %}
        <div data-map-detail-screenshot="{{ step.slug }}">
          {{ stepVariantScreenshot(step.defaultVariant) }}
        </div>
      {% endset %}

      {% set insightsTab %}
        <div class="map-step-tab-content">
          <div data-map-detail-insights="{{ step.slug }}">
            {{ stepVariantResearch(step.defaultVariant) }}
          </div>

          <section class="map-panel">
            <h2 class="nhsuk-heading-m">Notes</h2>
            <div data-map-detail-notes="{{ step.slug }}">
              <div class="map-rich-text">
                {{ (step.defaultVariant.notesHtml or step.notesHtml or '<p class="map-empty-state">None for this version</p>') | safe }}
              </div>
            </div>
          </section>

          {% if step.focusQuestions.length %}
            <section class="map-panel">
              <h2 class="nhsuk-heading-m">Research focus</h2>
              <ul class="nhsuk-list nhsuk-list--bullet">
                {% for question in step.focusQuestions %}
                  <li class="nhsuk-body-m">{{ question }}</li>
                {% endfor %}
              </ul>
            </section>
          {% endif %}

          {% if step.linkedInsights.length or step.linkedNextSteps.length %}
            <section class="map-panel">
              <h2 class="nhsuk-heading-m">Connected findings</h2>
              {% if step.linkedInsights.length %}
                <h3 class="nhsuk-heading-s">User insights</h3>
                {{ stepDetailList(step.linkedInsights) }}
              {% endif %}
              {% if step.linkedNextSteps.length %}
                <h3 class="nhsuk-heading-s">What to try next</h3>
                {{ stepDetailList(step.linkedNextSteps) }}
              {% endif %}
            </section>
          {% endif %}
        </div>
      {% endset %}

      {% set implementationTab %}
        <div data-map-detail-implementation="{{ step.slug }}">
          {{ stepImplementationPanel({ implementation: step.defaultVariant.implementation }) }}
        </div>
      {% endset %}

      {% set showImplementationTab = (step.status or '') | lower == 'ready for dev' %}

      {% if showImplementationTab %}
        {{ tabs({
          title: "Step detail sections",
          classes: "map-step-tabs",
          idPrefix: "map-step-tab",
          items: [
            {
              label: "Screenshot",
              id: "map-step-tab-screenshot",
              panel: {
                html: screenshotTab
              }
            },
            {
              label: "User insights",
              id: "map-step-tab-insights",
              panel: {
                html: insightsTab
              }
            },
            {
              label: "Implementation",
              id: "map-step-tab-implementation",
              panel: {
                html: implementationTab
              }
            }
          ]
        }) }}
      {% else %}
        {{ tabs({
          title: "Step detail sections",
          classes: "map-step-tabs",
          idPrefix: "map-step-tab",
          items: [
            {
              label: "Screenshot",
              id: "map-step-tab-screenshot",
              panel: {
                html: screenshotTab
              }
            },
            {
              label: "User insights",
              id: "map-step-tab-insights",
              panel: {
                html: insightsTab
              }
            }
          ]
        }) }}
      {% endif %}

      {% set previousPagination = step.previousStep and {
        href: step.previousStep.detailPath,
        text: "Previous step",
        labelText: "Step " ~ step.previousStep.position ~ ": " ~ step.previousStep.title
      } or null %}

      {% set nextPagination = step.nextStep and {
        href: step.nextStep.detailPath,
        text: "Next step",
        labelText: "Step " ~ step.nextStep.position ~ ": " ~ step.nextStep.title
      } or null %}

      {% if previousPagination or nextPagination %}
        <div class="map-step-pagination">
          {{ pagination({
            landmarkLabel: "Step navigation",
            previous: previousPagination,
            next: nextPagination
          }) }}
        </div>
      {% endif %}
    </section>
  </section>
{% endblock %}
